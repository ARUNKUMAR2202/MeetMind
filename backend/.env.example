# Copy this file to backend/.env (the backend loads it; the ai-pipeline package
# reads the same variables when imported by the backend, or you can also drop a
# copy at ai-pipeline/.env when running pipeline code standalone).

# --- Real integrations (required once USE_MOCK_PIPELINE=false) ---
OPENAI_API_KEY=
LLM_MODEL=gpt-4o
WHISPER_MODEL=whisper-1
EMBEDDING_MODEL=text-embedding-3-small

PINECONE_API_KEY=
PINECONE_INDEX=meetmind-documents

# --- Optional heavy/real AI backends (off by default — see ai-pipeline/requirements-real-*.txt) ---
# Real speaker diarization via pyannote.audio, instead of the pause-based heuristic.
# Needs `pip install -r requirements-real-diarization.txt` first, plus a HF token with
# access to pyannote/speaker-diarization-3.1 (see ai-pipeline/meetmind_ai/real_diarization.py).
USE_REAL_DIARIZATION=false
HUGGINGFACE_TOKEN=

# Real BERTScore for action-item extraction quality, instead of the confidence proxy.
# Needs `pip install -r requirements-real-bertscore.txt` first, and a reference summary
# to score against (see ai-pipeline/meetmind_ai/real_bertscore.py).
USE_REAL_BERTSCORE=false

# --- AWS S3 (optional — falls back to local disk under UPLOAD_DIR if unset) ---
AWS_S3_BUCKET=
AWS_REGION=us-east-1
UPLOAD_DIR=./uploads

# --- Backend ---
# Phase 1 (rooms/participants) works fine against the local SQLite default below —
# no Supabase account needed to test video conferencing in isolation. Once you have
# a Supabase project, point this at its Postgres connection string instead (Project
# Settings -> Database -> Connection string -> URI, "Session pooler" mode) and run
# supabase/migrations/0001_rooms.sql in the Supabase SQL Editor. docker-compose.yml
# overrides this to the local `db` container regardless of what's set here.
DATABASE_URL=sqlite:///./meetmind.db
JWT_SECRET=change-me-to-a-random-32-byte-string
JWT_EXPIRES_MINUTES=1440
# Comma-separated. Next.js falls back to 3001, 3002, etc. if 3000 is already taken
# by another process on your machine — add whichever port it actually printed.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Redis — backs session-status pub/sub and video-room signaling across multiple
# backend processes (see app/services/pubsub.py, room_manager.py). Leave empty to
# use in-memory fallback (fine for a single dev/demo process). Docker Compose sets
# this automatically to redis://redis:6379/0.
REDIS_URL=

# Rate limiting: 5/min on register, 10/min on login, 10/min on session upload
# (see app/rate_limit.py, routers/auth.py, routers/sessions.py for exact limits).
RATE_LIMIT_ENABLED=true
MAX_UPLOAD_SIZE_MB=200

# FERPA/GDPR: auto-delete stored audio (not transcripts/results) this many days
# after a session completes. 0 disables auto-deletion.
AUDIO_RETENTION_DAYS=30

# Auth: httpOnly cookie is set alongside the JSON token response on login/register
# (see app/auth.py) — the frontend relies on this instead of storing the raw JWT in
# localStorage, to reduce XSS exposure. Set COOKIE_SECURE=true once serving over
# HTTPS (cookies won't be sent over plain HTTP otherwise).
USE_COOKIE_AUTH=true
COOKIE_SECURE=false

# Set to "false" once you're ready to test against real audio + your own API keys.
# While "true", every session returns the same realistic sample data with zero API calls.
USE_MOCK_PIPELINE=true
